{
  "name": "kalos-assessment",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "turbo": "latest",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@prisma/client": "6.16.0",
    "bcryptjs": "^3.0.3",
    "prisma": "6.16.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.19.0"
}